# Server-only secrets for the /api/reviews Vercel function.
#
# Configure these in Vercel → Project → Settings → Environment Variables.
# DO NOT put real values in this file, in site.json, or with a VITE_ prefix
# (anything VITE_ is bundled into the public client). These are read ONLY by
# the serverless function, so the key never reaches the browser.
#
# Harden the key in Google Cloud: restrict it to the "Places API" and set a
# daily quota / budget cap.

GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
